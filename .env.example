# Screws Box Configuration
# Copy this file to .env and adjust values as needed.

# === Core ===
PORT=8080
DB_PATH=./screws_box.db

# === Sessions ===
# SESSION_TTL=24h
# REDIS_URL=redis://localhost:6379

# === Reverse proxy ===
# Comma-separated CIDRs of the reverse proxy(ies) in front of the app. When set,
# the client IP (for rate limiting + logging) is read from X-Forwarded-For,
# skipping these trusted hops. Leave unset if the app is reachable directly.
# TRUSTED_PROXY_CIDR=127.0.0.1/32

# === OIDC (seed-only: applied on first run if no config exists in DB) ===
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=screws-box
# OIDC_CLIENT_SECRET=your-secret-here
# OIDC_DISPLAY_NAME=Authelia
